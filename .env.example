# Backend
DATABASE_URL=postgresql+psycopg://pdflashcards:pdflashcards@db:5432/pdflashcards
SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# URLs
