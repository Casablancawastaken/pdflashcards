# Books API
GOOGLE_BOOKS_API_KEY=
BOOKS_TIMEOUT=5
BOOKS_MAX_RESULTS=6
BOOKS_RATE_LIMIT_PER_MINUTE=20

# Frontend
VITE_API_URL=http://localhost
